# Burn Server Configuration

# Server port
BURN_PORT=8091

# Quantization: q4 (fast, ~700MB VRAM) or bf16 (accurate, ~9GB VRAM)
BURN_QUANT=q4

# Shared model cache (default: ../../models/cache)
# STARLING_MODELS_DIR=../../models/cache

# Media directory (default: ../../media)
# BURN_MEDIA_DIR=../../media

# Frontend directory (default: ../../frontend)
# BURN_FRONTEND_PATH=../../frontend

# Public IP for WebRTC (optional, auto-detected)
# PUBLIC_IP=192.168.1.100

# TURN server (optional)
# TURN_SERVER=turn:turn.example.com
# TURN_USERNAME=user
# TURN_PASSWORD=pass
