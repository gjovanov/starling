# =============================================================================
# Burn Server Configuration
# =============================================================================
# Rust/Burn backend — runs Voxtral-Mini-4B directly on GPU (no separate model server)
# Supports Q4 (~700MB VRAM) and BF16 (~9GB VRAM) quantization
# All env vars are prefixed with BURN_

# =============================================================================
# Server
# =============================================================================

# Server port (default: 8091)
BURN_PORT=8091

# Quantization: q4 (fast, ~700MB VRAM) or bf16 (accurate, ~9GB VRAM)
BURN_QUANT=q4

# Maximum concurrent transcription sessions
MAX_CONCURRENT_SESSIONS=10

# =============================================================================
# Paths (relative to app dir, or absolute)
# =============================================================================

# Shared model cache directory
STARLING_MODELS_DIR=../../models/cache

# Shared media directory
BURN_MEDIA_DIR=../../media

# Shared frontend directory
BURN_FRONTEND_PATH=../../frontend

# =============================================================================
# WebRTC (optional, inherits from root .env if not set)
# =============================================================================

# Public IP for WebRTC (auto-detected if not set)
# PUBLIC_IP=192.168.1.100

# TURN server
# TURN_SERVER=turn:your-turn-server:3478
# TURN_USERNAME=user
# TURN_PASSWORD=pass
# TURN_SHARED_SECRET=
FORCE_RELAY=false
