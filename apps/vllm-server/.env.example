# =============================================================================
# vLLM Server Configuration
# =============================================================================
# Python/vLLM backend — serves Voxtral-Mini-4B in BF16 via OpenAI Realtime API
# All env vars are prefixed with VOXTRAL_

# =============================================================================
# Server
# =============================================================================

# Server port (default: 8090)
VOXTRAL_PORT=8090

# vLLM WebSocket URL (must be running Voxtral-Mini-4B-Realtime-2602)
VOXTRAL_VLLM_URL=ws://localhost:8001/v1/realtime

# vLLM GPU server port (used by start-vllm.sh)
VOXTRAL_VLLM_PORT=8001

# =============================================================================
# Paths (relative to app dir, or absolute)
# =============================================================================

# Shared media directory
VOXTRAL_MEDIA_DIR=../../media

# Shared frontend directory
VOXTRAL_FRONTEND_PATH=../../frontend

# Shared model cache (used by init.sh for download, start-vllm.sh for serving)
STARLING_MODELS_DIR=../../models/cache

# =============================================================================
# WebRTC (optional, inherits from root .env if not set)
# =============================================================================

# Public IP for WebRTC (auto-detected if not set)
# VOXTRAL_PUBLIC_IP=192.168.1.100

# TURN server
# VOXTRAL_TURN_SERVER=turn:your-turn-server:3478
# VOXTRAL_TURN_USERNAME=user
# VOXTRAL_TURN_PASSWORD=pass
# VOXTRAL_TURN_SHARED_SECRET=
# VOXTRAL_FORCE_RELAY=false
