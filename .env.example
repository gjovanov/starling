# =============================================================================
# Starling Monorepo — Shared Configuration
# =============================================================================
# Copy this file to .env and modify as needed.
# App-specific settings go in apps/vllm-server/.env or apps/burn-server/.env

# =============================================================================
# HuggingFace Authentication
# =============================================================================

# HuggingFace token for model downloads (Voxtral requires access request)
# Get yours at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxx

# =============================================================================
# Shared Model Storage
# =============================================================================

# Shared model cache directory (used by all apps)
# Default: ./models/cache (relative to repo root)
# Both vllm-server and burn-server read from this directory
STARLING_MODELS_DIR=./models/cache

# =============================================================================
# WebRTC / ICE Configuration (shared by all apps)
# =============================================================================

# Public IP for WebRTC ICE candidates (auto-detected if not set)
# Required for NAT traversal when server is behind a router
# PUBLIC_IP=192.168.1.100

# TURN server for strict NAT traversal (optional)
# TURN_SERVER=turn:your-turn-server:3478
# TURN_USERNAME=user
# TURN_PASSWORD=pass

# COTURN ephemeral credentials (shared secret mode)
# When set, overrides static TURN_USERNAME/TURN_PASSWORD
# TURN_SHARED_SECRET=

# Force TURN relay mode (use when direct/STUN connectivity fails)
FORCE_RELAY=false
