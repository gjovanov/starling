# Starling Configuration
# All env vars are prefixed with VOXTRAL_

# vLLM server URL (must be running Voxtral-Mini-4B-Realtime-2602)
VOXTRAL_VLLM_URL=ws://localhost:8001/v1/realtime

# Server port
VOXTRAL_PORT=8090

# Media directory
VOXTRAL_MEDIA_DIR=./media

# Frontend directory
VOXTRAL_FRONTEND_PATH=./frontend

# Public IP for WebRTC (optional, auto-detected if not set)
# VOXTRAL_PUBLIC_IP=192.168.1.100

# TURN server (optional)
# VOXTRAL_TURN_SERVER=turn:turn.example.com
# VOXTRAL_TURN_USERNAME=user
# VOXTRAL_TURN_PASSWORD=pass
