# Python
.venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Rust
target/
wasm/pkg/

# Environment
.env

# Media files
media/
*.wav
*.mp3
*.flac
*.ogg

# Models (shared cache)
models/cache/
*.bin
*.onnx
*.safetensors
*.pt
*.gguf

# Exempt regression-test fixtures from the media/model exclusions above.
# These are small (~10 MB total), versioned, and load-bearing for the
# Rust port's bit-exact regression tests.
!apps/burn-server/test_data/**

# Logs
*.log
crash.log

# IDE
.idea/
.vscode/
*.DS_Store

# Benchmark results
scripts/benchmark_results/
# Exclude WASM build artifacts (generated by wasm-pack)
frontend/wasm/pkg/
apps/wasm-poc/pkg/

# Node.js / JS tooling
node_modules/
**/node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
npm-debug.log*
.npm/
.yarn/

# Python test artifacts
test-results/
.pytest_cache/
.coverage
htmlcov/
**/test-results/

# Local debugging / scratch artifacts
**/cpu_batch_output.txt
*.tmp
*.bak
/tmp_*

# Editor / OS junk
*.swp
*.swo
*~
Thumbs.db

# Claude Code session metadata
.claude/
